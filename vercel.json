{
  "version": 2,
  "routes": [
    {
      "src": "/privacy.html",
      "dest": "/privacy.html"
    },
    {
      "src": "/terms.html",
      "dest": "/terms.html"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-reminders",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/reset-weekly-xp",
      "schedule": "0 0 * * 1"
    }
  ]
}


